package mnemra:host@0.0.1;

interface echo {
    /// Round-trip: returns "echo: <s>". Validates host-fn parameters and return values.
    echo: func(s: string) -> string;

    /// Stateful: returns a host-side counter that increments on every call.
    /// Validates state persistence across invocations on the same component instance.
    increment-counter: func() -> u32;
}

world plugin {
    import echo;

    /// Artifact CRUD host-fns (declared in wit/host.wit).
    /// Imported here so the plugin guest can call back into the host to persist
    /// and read artifacts from within its `content` export bodies (the
    /// guest-driven invocation model: host invokes `content.create`, the guest
    /// body calls `artifact.artifact-create`).
    ///
    /// R-0003-a: core: true plugins import artifact as part of their ABI surface.
    import artifact;

    /// Typed content export — the fixed CRUD surface (R-0019-a, P-0013).
    /// The host invokes one typed method per MCP verb (static verb->export
    /// resolution, R-0019-c); `run(string) -> string` is RETIRED (R-0019-e:
    /// no string-dispatch export).
    export content;
}
