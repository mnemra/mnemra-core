package mnemra:host@0.0.2;

/// Shared types used across all host-fn interfaces.
interface types {
    /// Opaque JSON value — serialised as a UTF-8 string.
    /// Must not be list<u8> (R-0012-f).
    type json = string;

    /// Host-derived workspace context.  Carried as the first parameter of
    /// every host-fn (R-0006-a).  Declared as a record so the named type
    /// survives wit-parser's typedef resolution and `type_is_named` passes.
    ///
    /// Note: a resource handle would provide stronger spoof-resistance
    /// (the host controls construction), but the contract test resolves
    /// `workspace-ctx` via `Type::Id → TypeDef.name`, which only works for
    /// records and type-aliases, not resource own/borrow handles.  This is
    /// flagged in the completion report for the spec owner.
    record workspace-ctx {
        /// Workspace identifier — host-derived, never a bare host-fn param.
        workspace-id: string,
    }

    /// Paged result for artifact-list operations (R-0020).
    ///
    /// `ids` holds the artifact ids visible in the caller's workspace for
    /// this page.  `has-more` is true when additional pages exist beyond
    /// this one.  `next-cursor` is the opaque continuation token to supply
    /// on the next call; `none` when `has-more` is false.
    ///
    /// T14: host body returns placeholder paging only (has-more=false,
    /// next-cursor=none); keyset/clamp/cursor logic lands in later tasks.
    record artifact-page {
        ids: list<string>,
        has-more: bool,
        next-cursor: option<string>,
    }
}

/// Typed content export interface — the fixed CRUD surface EVERY content plugin
/// EXPORTS (R-0019-a, P-0013).  The host invokes one of these typed methods per
/// MCP verb (static verb->export resolution, R-0019-c); the guest body calls back
/// into the host `artifact` import to persist / read.
///
/// This is the EXPORT side (guest-implemented), distinct from the `artifact`
/// IMPORT below (host-implemented).  The two share the JSON-as-string convention
/// (`type json = string`) but NOT the ctx parameter: ctx is host-derived and
/// threaded on the import side; the host carries it across the export boundary
/// itself, so the export methods do not take a ctx (R-0019-a).
///
/// FENCE (R-0019-c/d): the verb->export mapping is static against this fixed
/// interface — no runtime export registry, no dynamic verb->export resolution,
/// no `run(string)`-style string-dispatch export.
///
/// R-0019-a, R-0019-e
interface content {
    use types.{json, artifact-page};

    /// Create a new artifact of `type` and return its generated id (ULID).
    ///
    /// R-0019-a
    @since(version = 0.0.1)
    create: func(%type: string, frontmatter: json, body: option<string>) -> string;

    /// Retrieve a single artifact by id; `none` if not found / not visible.
    ///
    /// R-0019-a
    @since(version = 0.0.1)
    get: func(id: string) -> option<string>;

    /// List artifacts of `type` matching `filters` with paging (R-0020).
    ///
    /// `limit` caps the number of ids returned (0 = host-default).
    /// `cursor` resumes from a prior page (none = first page).
    /// Returns an `artifact-page` with the visible ids and a continuation
    /// token; T14 host body returns placeholder paging only.
    ///
    /// Breaking change from 0.0.1 (list<string>) — R-0020, R-0017-a.
    ///
    /// R-0019-a, R-0020
    @since(version = 0.0.2)
    %list: func(%type: string, filters: json, limit: u32, cursor: option<string>) -> artifact-page;

    /// Patch an artifact's frontmatter and/or body.
    ///
    /// R-0019-a
    @since(version = 0.0.1)
    update: func(id: string, frontmatter-patch: json, body: option<string>);

    /// Permanently delete an artifact.
    ///
    /// R-0019-a
    @since(version = 0.0.1)
    delete: func(id: string);
}

/// Artifact CRUD host-fns.  All write-path fns derive workspace from ctx;
/// workspace-id never appears as a standalone parameter (R-0012-d, R-0003-d).
///
/// R-0012-a, R-0003-g
interface artifact {
    use types.{json, workspace-ctx, artifact-page};

    /// Create a new artifact and return its generated id.
    ///
    /// R-0012-a
    @since(version = 0.0.1)
    artifact-create: func(ctx: workspace-ctx, %type: string, frontmatter: json, body: option<string>) -> string;

    /// Patch an artifact's frontmatter and/or body.
    ///
    /// R-0012-a
    @since(version = 0.0.1)
    artifact-update: func(ctx: workspace-ctx, id: string, frontmatter-patch: json, body: option<string>);

    /// Retrieve a single artifact by id.
    ///
    /// R-0012-a
    @since(version = 0.0.1)
    artifact-get: func(ctx: workspace-ctx, id: string) -> option<string>;

    /// List artifacts by type with optional filter criteria and paging (R-0020).
    ///
    /// `limit` caps the number of ids returned (0 = host-default).
    /// `cursor` resumes from a prior page (none = first page).
    /// Returns an `artifact-page` with the visible ids and a continuation
    /// token; T14 host body returns placeholder paging only.
    ///
    /// Breaking change from 0.0.1 (list<string>) — R-0020, R-0017-a.
    ///
    /// R-0012-a, R-0020
    @since(version = 0.0.2)
    artifact-list: func(ctx: workspace-ctx, %type: string, filters: json, limit: u32, cursor: option<string>) -> artifact-page;

    /// Permanently delete an artifact.  Opt-in at the host_fns.required
    /// declaration level (R-0003-g).
    ///
    /// R-0012-a, R-0003-g
    @since(version = 0.0.1)
    artifact-delete: func(ctx: workspace-ctx, id: string);
}

/// Structured metrics emission.
///
/// R-0012-a
interface metrics {
    use types.{workspace-ctx};

    /// Record a single metric observation.
    ///
    /// R-0012-a
    @since(version = 0.0.1)
    metrics-record: func(ctx: workspace-ctx, verb: string, duration-ms: u64, outcome: string);
}

/// Structured log emission.
///
/// R-0012-a
interface log {
    use types.{json, workspace-ctx};

    /// Emit a structured log line.
    ///
    /// R-0012-a
    @since(version = 0.0.1)
    log-emit: func(ctx: workspace-ctx, level: string, message: string, context: option<json>);
}

/// Domain event emission.
///
/// R-0012-a
interface event {
    use types.{json, workspace-ctx};

    /// Emit a versioned domain event.
    ///
    /// R-0012-a
    @since(version = 0.0.1)
    event-emit: func(ctx: workspace-ctx, event-type: string, event-version: u16, payload: json);
}

/// Projection (read-model) update emission.
///
/// R-0012-a, R-0003-d
interface projection {
    use types.{json, workspace-ctx};

    /// Emit a named projection update.  Workspace is derived from ctx —
    /// workspace-id is never an explicit parameter (R-0003-d).
    ///
    /// R-0012-a
    @since(version = 0.0.1)
    projection-emit: func(ctx: workspace-ctx, projection-name: string, data: json);
}

/// Sampling / LLM-inference request.  Optional opt-in surface (R-0012-b).
/// context-ids are opaque handle strings; the host never resolves them to
/// artifact bodies within this interface.
///
/// R-0012-b
interface sampling {
    use types.{json, workspace-ctx};

    /// Request a sampling inference.  context-ids carries references to
    /// context artifacts; bodies are not passed across the ABI boundary
    /// (R-0012-b — host never resolves IDs to bodies inside this call).
    ///
    /// Marked @unstable: the sampling protocol shape may change as the
    /// LLM integration layer evolves.
    ///
    /// R-0012-b
    @unstable(feature = sampling-v0)
    sampling-request: func(ctx: workspace-ctx, context-ids: list<string>, prompt: string) -> option<string>;
}

/// Secrets read surface.  Optional opt-in; no write path at V0 (R-0012-c).
///
/// R-0012-c
interface secrets {
    use types.{workspace-ctx};

    /// Retrieve a secret value by name.  Read-only; no secrets-set / secrets-delete.
    ///
    /// R-0012-c
    @since(version = 0.0.1)
    secrets-get: func(ctx: workspace-ctx, name: string) -> option<string>;
}
